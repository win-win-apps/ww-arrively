{% comment %}
  Arrively — Estimated Delivery Date block
  Reads config from app metafields and per-product rules.
  Renders a delivery window message with optional truck icon.
  Listens to variant changes to update per-variant windows.
{% endcomment %}

{% comment %}
  APP_ID bracket notation required — see hard-won-fixes #1.
  The $app namespace is stored as app--{APP_ID}.
  APP_ID = numeric ID from dev.shopify.com/dashboard/131669393/apps/{APP_ID}
{% endcomment %}
{% assign config_raw = app.metafields['app--343028105217']['config'] %}
{% assign rules_raw = app.metafields['app--343028105217']['rules'] %}
{% assign badges_raw = app.metafields['app--343028105217']['badges'] %}
{% assign zones_raw = app.metafields['app--343028105217']['zones'] %}
{% assign config = config_raw.value %}
{% assign rules_json = rules_raw.value %}
{% assign badges_json = badges_raw.value %}
{% assign zones_json = zones_raw.value %}

{% comment %} Use sensible defaults when merchant hasn't saved Settings yet {% endcomment %}
{% if config == blank %}
  {% assign config = '{"processingDays":"1","shippingDaysMin":"3","shippingDaysMax":"7","cutoffHour":"14","cutoffTimezone":"America/New_York","excludeWeekends":true,"holidays":[],"messageTemplate":"Get it {date_range}","showTruckIcon":true,"accentColor":"#2C6ECB","manualPlacementSelector":""}' %}
{% endif %}

{% comment %} Render on all product pages — config defaults ensure it always works {% endcomment %}
{% if product %}

{% assign product_rule_raw = product.metafields['app--343028105217']['delivery_rule'] %}
{% assign product_rule = product_rule_raw.value %}

{% comment %} Collect product tags as comma-separated string {% endcomment %}
{% assign product_tags_str = product.tags | join: ',' %}

{% comment %} Collect product collection IDs as comma-separated string {% endcomment %}
{% assign collection_ids_arr = '' %}
{% for c in product.collections %}
  {% if forloop.first %}
    {% assign collection_ids_arr = c.id | append: '' %}
  {% else %}
    {% assign collection_ids_arr = collection_ids_arr | append: ',' | append: c.id %}
  {% endif %}
{% endfor %}

{% comment %}
  Customer geo: use shipping address if logged in, otherwise fall back to
  the storefront's selected/detected country (localization.country).
  Province code is only available from the customer's saved address.
{% endcomment %}
{%- if customer and customer.default_address -%}
  {%- assign customer_country = customer.default_address.country_code -%}
  {%- assign customer_province = customer.default_address.province_code -%}
{%- else -%}
  {%- assign customer_country = localization.country.iso_code -%}
  {%- assign customer_province = '' -%}
{%- endif -%}

<div
  id="arrively-widget"
  class="arrively-widget arrively-style-card arrively-preview arrively-align-left"
  data-config="{{ config | json | escape }}"
  data-manual-selector="{{ config.manualPlacementSelector | default: '' | escape }}"
  data-rules="{{ rules_json | json | escape }}"
  data-badges="{{ badges_json | json | escape }}"
  data-zones="{{ zones_json | json | escape }}"
  data-product-id="{{ product.id }}"
  data-product-rule="{{ product_rule | json | escape }}"
  data-variants="{{ product.variants | map: 'id' | json | escape }}"
  data-product-tags="{{ product_tags_str | escape }}"
  data-product-collections="{{ collection_ids_arr | escape }}"
  data-customer-country="{{ customer_country | escape }}"
  data-customer-province="{{ customer_province | escape }}"
>
  <div id="arrively-embed-loaded" style="display:none"></div>
  <div class="arrively-inner">
    <span class="arrively-icon" aria-hidden="true" style="display:none"></span>
    <span class="arrively-message">
      <span class="arrively-card-label">This is a preview</span>
      <span class="arrively-card-body">
        <span class="arrively-card-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" style="color:#2C6ECB" aria-hidden="true"><path d="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4zM6 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm13.5-9l1.96 2.5H17V9.5h2.5zm-1.5 9c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z" fill="currentColor"/></svg>
        </span>
        <span class="arrively-card-text">
          <span class="arrively-card-headline">Estimated delivery dates appear here</span>
          <span class="arrively-card-subtext">Click Save to activate this embed</span>
        </span>
      </span>
    </span>
  </div>
</div>

{{ 'arrively.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Inline placement: move #arrively-widget to just before the Add to Cart buttons.
  Runs immediately (non-deferred) so the widget is in the right place before
  the deferred arrively.js runs and makes it visible.
  Tries multiple selectors to support Dawn, Sense, Refresh and other themes.
{%- endcomment -%}
<script>
(function() {
  function placeArrivWidget() {
    var w = document.getElementById('arrively-widget');
    if (!w) return;
    var manualSel = (w.dataset.manualSelector || '').trim();
    if (manualSel) {
      try {
        var mt = document.querySelector(manualSel);
        if (mt && mt.parentNode) { mt.parentNode.insertBefore(w, mt); return; }
      } catch(e) {}
    }
    var targets = [
      '.product-form__buttons', 'buy-buttons',
      '.product-purchase', '.product-purchase-button',
      '.product__payment-button-set', '.product-form__actions',
      '.purchase-info__actions', '.product-form__item--submit',
      '.product-form .product-form__controls-group--submit',
      '.product-single-form .product-form__controls-group',
      '.product-single__add-to-cart',
      '.shopify-payment-button', '.product-form', 'product-form'
    ];
    for (var i = 0; i < targets.length; i++) {
      var t = document.querySelector(targets[i]);
      if (t && t.parentNode) { t.parentNode.insertBefore(w, t); return; }
    }
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', placeArrivWidget);
  } else {
    placeArrivWidget();
  }
})();
</script>

<script src="{{ 'arrively.js' | asset_url }}" defer></script>

{% endif %}

{% schema %}
{
  "name": "Estimated Delivery Date",
  "target": "body",
  "settings": []
}
{% endschema %}
